{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/ai-learning-progress",
      "regex": "^/ai\\-learning\\-progress(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ai\\-learning\\-progress(?:/)?$"
    },
    {
      "page": "/announcements",
      "regex": "^/announcements(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/announcements(?:/)?$"
    },
    {
      "page": "/attendance",
      "regex": "^/attendance(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/attendance(?:/)?$"
    },
    {
      "page": "/behaviour",
      "regex": "^/behaviour(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/behaviour(?:/)?$"
    },
    {
      "page": "/calendar",
      "regex": "^/calendar(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/calendar(?:/)?$"
    },
    {
      "page": "/child-progress",
      "regex": "^/child\\-progress(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/child\\-progress(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/homework",
      "regex": "^/homework(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/homework(?:/)?$"
    },
    {
      "page": "/profile",
      "regex": "^/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/profile(?:/)?$"
    },
    {
      "page": "/rewards",
      "regex": "^/rewards(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/rewards(?:/)?$"
    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings(?:/)?$"
    },
    {
      "page": "/teacher-messages",
      "regex": "^/teacher\\-messages(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/teacher\\-messages(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
}